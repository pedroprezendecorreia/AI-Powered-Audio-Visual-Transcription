/* Whisper Transcriber — modern dark theme (hand-styled, no component kit) */

QWidget {
    background-color: #16161e;
    color: #c8d3f5;
    font-family: "Segoe UI", "Inter", Arial, sans-serif;
    font-size: 10pt;
}

QMainWindow {
    background-color: #16161e;
    border: none;
}

/* ---- Header bar ---- */
#headerBar {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                stop:0 #24283b, stop:1 #2d3350);
    border: 1px solid #2f334d;
    border-radius: 12px;
}
#appTitle {
    color: #ffffff;
    font-size: 19pt;
    font-weight: 700;
    background: transparent;
}
#appSubtitle {
    color: #8f9bd4;
    font-size: 10pt;
    background: transparent;
}

/* ---- Buttons ---- */
QPushButton {
    background-color: #2a2f45;
    color: #c8d3f5;
    border: 1px solid #3a4162;
    border-radius: 8px;
    padding: 8px 16px;
    min-width: 84px;
    min-height: 20px;
    font-weight: 600;
}
QPushButton:hover {
    background-color: #343b57;
    border: 1px solid #4d69b1;
}
QPushButton:pressed {
    background-color: #232840;
}
QPushButton:disabled {
    background-color: #1f2233;
    color: #4b5477;
    border: 1px solid #262a40;
}

/* Primary action buttons (Transcribe / Process All) */
QPushButton#primary, QPushButton[text="Transcribe"], QPushButton[text="Process All"] {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #7aa2f7, stop:1 #5f86e6);
    color: #0c0f1a;
    border: none;
}
QPushButton[text="Transcribe"]:hover, QPushButton[text="Process All"]:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                stop:0 #8fb3ff, stop:1 #6f93f0);
}
QPushButton[text="Transcribe"]:disabled, QPushButton[text="Process All"]:disabled {
    background: #2a2f45;
    color: #4b5477;
}

/* ---- Inputs ---- */
QLineEdit, QTextEdit, QPlainTextEdit {
    background-color: #1e2030;
    color: #c8d3f5;
    border: 1px solid #2f334d;
    border-radius: 8px;
    padding: 7px 10px;
    min-height: 20px;
    selection-background-color: #3d59a1;
}
QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 1px solid #7aa2f7;
}

/* ---- Lists ---- */
QListWidget, QTreeWidget, QTableWidget {
    background-color: #1e2030;
    alternate-background-color: #232538;
    border: 1px solid #2f334d;
    border-radius: 8px;
    padding: 4px;
    outline: none;
}
QListWidget::item, QTreeWidget::item {
    padding: 6px 8px;
    border-radius: 6px;
}
QListWidget::item:selected, QTreeWidget::item:selected, QTableWidget::item:selected {
    background-color: #3d59a1;
    color: #ffffff;
}
QListWidget::item:hover, QTreeWidget::item:hover {
    background-color: #2a2f45;
}

/* ---- Scrollbars ---- */
QScrollBar:vertical {
    background-color: transparent;
    width: 10px;
    margin: 2px;
}
QScrollBar::handle:vertical {
    background-color: #3a4162;
    min-height: 28px;
    border-radius: 5px;
}
QScrollBar::handle:vertical:hover { background-color: #4d5680; }
QScrollBar:horizontal {
    background-color: transparent;
    height: 10px;
    margin: 2px;
}
QScrollBar::handle:horizontal {
    background-color: #3a4162;
    min-width: 28px;
    border-radius: 5px;
}
QScrollBar::handle:horizontal:hover { background-color: #4d5680; }
QScrollBar::add-line, QScrollBar::sub-line { height: 0; width: 0; }
QScrollBar::add-page, QScrollBar::sub-page { background: transparent; }

/* ---- Tabs (pill style) ---- */
QTabWidget::pane {
    border: 1px solid #2f334d;
    border-radius: 10px;
    top: -1px;
    padding: 6px;
}
QTabBar::tab {
    background-color: transparent;
    color: #8f9bd4;
    border: none;
    padding: 8px 18px;
    margin-right: 4px;
    border-radius: 8px;
    font-weight: 600;
}
QTabBar::tab:selected {
    background-color: #2d3350;
    color: #ffffff;
}
QTabBar::tab:hover:!selected {
    background-color: #232840;
    color: #c8d3f5;
}

/* ---- Combobox ---- */
QComboBox {
    background-color: #1e2030;
    color: #c8d3f5;
    border: 1px solid #2f334d;
    border-radius: 8px;
    padding: 7px 10px;
    min-width: 6em;
    min-height: 20px;
}
QComboBox:hover { border: 1px solid #4d69b1; }
QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 22px;
    border: none;
}
QComboBox QAbstractItemView {
    background-color: #1e2030;
    border: 1px solid #2f334d;
    border-radius: 8px;
    selection-background-color: #3d59a1;
    padding: 4px;
    outline: none;
}

/* ---- Check / radio ---- */
QCheckBox, QRadioButton {
    color: #c8d3f5;
    spacing: 8px;
    background: transparent;
}
QCheckBox::indicator, QRadioButton::indicator {
    width: 18px;
    height: 18px;
}
QCheckBox::indicator { border-radius: 5px; }
QRadioButton::indicator { border-radius: 9px; }
QCheckBox::indicator:unchecked, QRadioButton::indicator:unchecked {
    background-color: #1e2030;
    border: 2px solid #3a4162;
}
QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: #7aa2f7;
    border: 2px solid #7aa2f7;
}

/* ---- Progress bar ---- */
QProgressBar {
    background-color: #1e2030;
    border: 1px solid #2f334d;
    border-radius: 9px;
    text-align: center;
    color: #c8d3f5;
    height: 18px;
    font-weight: 600;
}
QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                stop:0 #7aa2f7, stop:1 #bb9af7);
    border-radius: 8px;
    margin: 1px;
}

/* ---- Group boxes (cards) ---- */
QGroupBox {
    background-color: #1a1b28;
    border: 1px solid #2f334d;
    border-radius: 10px;
    margin-top: 14px;
    padding: 14px 12px 10px 12px;
    font-weight: 600;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 2px 8px;
    color: #8fb3ff;
    background: transparent;
}

/* ---- Misc ---- */
QToolTip {
    background-color: #24283b;
    color: #c8d3f5;
    border: 1px solid #3a4162;
    border-radius: 6px;
    padding: 4px 8px;
}
QStatusBar {
    background-color: #1a1b28;
    color: #8f9bd4;
    border-top: 1px solid #2f334d;
}
QStatusBar::item { border: none; }

QFrame[frameShape="4"], QFrame[frameShape="5"] {
    color: #2f334d;
    max-height: 1px;
}

QSplitter::handle {
    background-color: transparent;
}
QSplitter::handle:vertical { height: 8px; }
